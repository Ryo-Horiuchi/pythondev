nums = []

for n in range(1, 101):

    result = str(n)

    if  n % 15 == 0:
        result = "FizzBuzz"

    elif n % 5 == 0:
        result = "Buzz"

    elif n % 3 == 0:
        result = "Fizz"

    nums.append(result)

print(nums)


