for i in range(1,101):  #1から100まで繰り返す

  if i == 1 :           #1は素数ではないのでスキップ 
    continue

  if i in (2, 3, 5, 7): #2,3,5,7は素数 
    print(f"{i}")       
    continue

  if ( i % 2 == 0       #2,3,5,7の倍数は素数ではないのでスキップ
    or i % 3 == 0       
    or i % 5 == 0       
    or i % 7 == 0 ):    
    continue

  print(f"{i}")         #表示 
